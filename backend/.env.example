# Arc Testnet
ARC_RPC_URL="https://rpc.testnet.arc.network"
ARC_TESTNET_RPC_URL="https://rpc.testnet.arc.network"
ARC_CHAIN_ID=5042002

# Autonomi — set to the contract you want the backend to use
# First deploy (permissioned USYC):
AUTONOMI_ADDRESS="0x4b7f00672B96B489F227469f9c106623d5de5779"
MOCK_TELLER_ADDRESS="0xbc806B10D04A8D82b2e7A0f17B6dC86E489E3b75"
# Mock collateral deploy (testing without permissioning) — uncomment to use:
# AUTONOMI_ADDRESS="0xBF0CD2266aC07C4D4961EeF99d306f8e5bfd44C4"
# MOCK_USYC_ADDRESS="0xC0A6332Ff8D3Be853949050184e10d89517b4588"
# MOCK_TELLER_ADDRESS="0xa0aAFe2Ef30cc7AF94dEaC465520D44A31d9b567"

# Agent = wallet that can call autoRebalance(). Use the SAME key as your deployer.
# Copy your deployer private key here (64 hex chars, with or without 0x).
# Then on-chain run (as owner): cast send $AUTONOMI_ADDRESS "authorizeAgent(address)" <YOUR_DEPLOYER_ADDRESS> --rpc-url $ARC_TESTNET_RPC_URL --private-key $PRIVATE_KEY
# You can also set PRIVATE_KEY instead of AGENT_PRIVATE_KEY — the agent will use whichever is set.
AGENT_PRIVATE_KEY="0x..."

# Optional: comma-separated list of addresses to monitor (defaults to your deployer address)
# WATCH_ADDRESSES="0x6C9365Ca168953BEEE77Cd8332a1d3B5Ae557515,0x..."

# Optional: simulate USYC price drop for testing (e.g. 0.95 = $0.95). Agent uses this for LTV so rebalance can trigger.
# SIMULATE_USYC_PRICE=0.95

# Optional: Circle Developer-Controlled Wallets (for creating/funding agent wallet)
# CIRCLE_API_KEY="..."
# CIRCLE_ENTITY_SECRET="..."

# Server
PORT=3000

# Dashboard API: when ?address= is omitted, uses first WATCH_ADDRESSES entry or AUTONOMI_DEFAULT_VIEWER
# AUTONOMI_DEFAULT_VIEWER="0x6C9365Ca168953BEEE77Cd8332a1d3B5Ae557515"
